{
  "name": "wrenlo",
  "version": "0.1.0",
  "description": "wrenlo — SMB AI receptionist platform",
  "type": "module",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc && cp -r src/db dist/ && cp -r src/public dist/",
    "start": "node dist/server.js",
    "db:init": "node --input-type=module < src/db/init.mjs",
    "db:seed": "node --input-type=module < src/db/seed.mjs"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/static": "^8.0.0",
    "better-sqlite3": "^11.0.0",
    "fastify": "^5.0.0",
    "dotenv": "^16.0.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
